<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:id="@+id/topBarAdminPuntos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/admin_dark"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="8dp">

        <TextView
            android:id="@+id/btnBackAdminPuntos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="28sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestión Logística"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textAllCaps="true"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Puntos de Control"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <org.osmdroid.views.MapView
        android:id="@+id/mapAdmin"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBarAdminPuntos"
        app:layout_constraintBottom_toBottomOf="parent" />

    <HorizontalScrollView
        android:id="@+id/scrollPuntosRapidos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/cardInfoPunto">

        <LinearLayout
            android:id="@+id/layoutPuntosRapidos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInfoPunto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="24dp"
        app:cardCornerRadius="24dp"
        android:layout_marginBottom="-20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingBottom="44dp">

            <TextView
                android:id="@+id/tvSeleccionaPunto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecciona un marcador o mantén presionado el mapa para añadir uno nuevo."
                android:textColor="@color/text_sub"
                android:textAlignment="center"
                android:textSize="14sp"
                android:paddingVertical="30dp"/>

            <LinearLayout
                android:id="@+id/layoutEdicionPunto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvNombrePuntoEdicion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Punto: -"
                    android:textColor="@color/admin_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerEstadoPunto"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bot_bubble_bg"/>

                <TextView
                    android:id="@+id/tvLabelCapacidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Nivel de Llenado: 0%"
                    android:textColor="@color/admin_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderCapacidad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:valueFrom="0.0"
                    android:valueTo="100.0"
                    app:thumbColor="@color/admin_dark"
                    app:trackColorActive="@color/admin_dark"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardarPunto"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:text="Actualizar Infraestructura"
                    android:backgroundTint="@color/admin_dark"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>