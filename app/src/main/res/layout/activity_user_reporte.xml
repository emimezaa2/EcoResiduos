<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <View
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/btnBackReporte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Volver"
        android:textSize="16sp"
        android:textColor="@color/text_sub"
        android:textStyle="bold"
        android:padding="24dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitleReporte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar Carga"
        android:textColor="@color/text_dark"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginStart="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBackReporte" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFoto"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#F8FAFC"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="2dp"
        app:strokeColor="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@id/tvTitleReporte">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/ivEvidencia"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
            <LinearLayout
                android:id="@+id/placeholderFoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/text_sub"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fotografiar Evidencia"
                    android:textColor="@color/text_sub"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleTipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btnOrganico"
        app:layout_constraintTop_toBottomOf="@id/cardFoto">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOrganico"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:text="Orgánico"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeco"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:text="Seco"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPeso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/toggleTipo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvDisplayPeso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.5 kg"
                android:textColor="@color/green_primary"
                android:textSize="36sp"
                android:textStyle="bold"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:valueFrom="0.5"
                android:valueTo="50.0"
                android:value="0.5"
                android:stepSize="0.5"
                app:thumbColor="@color/green_primary"
                app:trackColorActive="@color/green_primary"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutPunto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardPeso">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Punto de Entrega"
            android:textColor="@color/text_sub"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerPuntos"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bot_bubble_bg"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinalizarReporte"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="@color/admin_dark"
        android:text="Registrar en Sistema"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>